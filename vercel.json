{
  "build": {
    "env": {
      "HUGO_VERSION": "0.120.0"
    }
  },
  "framework": "hugo",
  "installCommand": "curl -L https://github.com/gohugoio/hugo/releases/download/v0.120.0/hugo_extended_0.120.0_linux-amd64.tar.gz | tar xz && mv hugo /usr/local/bin/",
  "buildCommand": "hugo --minify",
  "outputDirectory": "public"
}
